# Database
DATABASE_URL=sqlite:///./confessions.db
# For PostgreSQL: postgresql://user:password@localhost/confession_db

# Instagram API Credentials
INSTAGRAM_USER_ID=your_instagram_user_id_here
INSTAGRAM_ACCESS_TOKEN=your_instagram_access_token_here
# Optional: public URL for image links (e.g. ngrok tunnel for local testing)
# PUBLIC_BASE_URL=https://abc123.ngrok.io
# Optional: ImgBB API key – uploads images to ImgBB so Instagram gets a fast CDN URL (recommended if tunnels time out)
# Get a free key at https://api.imgbb.com/ . Set IMGBB_API_KEY=your_key

# Admin UI (required for /admin login; approval flow → SQS → Lambda)
ADMIN_PASSWORD=your-admin-password-here
# SQS_QUEUE_URL=https://sqs.region.amazonaws.com/account/queue-name
# PUBLIC_BASE_URL=https://your-domain.com  # Required when approving (image URL for Lambda)

# Application Settings
MAX_CONFESSION_LENGTH=500
RATE_LIMIT_PER_HOUR=10
SECRET_KEY=your-secret-key-change-this-in-production

# AWS Configuration
AWS_REGION=eu-north-1
AWS_ACCESS_KEY_ID=your_access_key_id
AWS_SECRET_ACCESS_KEY=your_secret_access_key
S3_BUCKET_NAME=soothing-playlist

# Environment
ENVIRONMENT=development
